<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.PagosController"
      styleClass="main_container"
      stylesheets="@../css/pagos_style.css">

    <HBox alignment="CENTER_LEFT" spacing="20">
        <VBox spacing="2" HBox.hgrow="ALWAYS">
            <Label text="Historial de Pagos" styleClass="title_label"/>
            <Label text="Gestión y control de transacciones mensuales" styleClass="subtitle_label"/>
        </VBox>
        <Button text="Reiniciar Mes" onAction="#resetearEstadisticas" styleClass="btn-danger"/>
    </HBox>

    <HBox styleClass="card_container">
        <VBox styleClass="summary_card card_ingresos" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <javafx.scene.shape.SVGPath content="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z" styleClass="icon_ingresos"/>
                <Label text="INGRESOS DEL MES" styleClass="card_title"/>
            </HBox>
            <Label fx:id="lbl_ingresos" styleClass="card_value_ingresos"/>
        </VBox>

        <VBox styleClass="summary_card card_pendientes" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <javafx.scene.shape.SVGPath content="M1 21h22L12 2 1 21zm12-3h-2v-2h2v2zm0-4h-2v-4h2v4z" styleClass="icon_pendientes"/>
                <Label text="PAGOS PENDIENTES" styleClass="card_title"/>
            </HBox>
            <Label fx:id="lbl_pendientes" styleClass="card_value_pendientes"/>
        </VBox>

        <VBox styleClass="summary_card card_alumnos" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <javafx.scene.shape.SVGPath content="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" styleClass="icon_alumnos"/>
                <Label text="TOTAL ALUMNOS" styleClass="card_title"/>
            </HBox>
            <Label fx:id="lbl_alumnos" styleClass="card_value_alumnos"/>
        </VBox>
    </HBox>

    <TableView fx:id="tbl_movimientos" VBox.vgrow="ALWAYS" style="-fx-margin-top: 15px;" styleClass="pagos_table">
        <columns>
            <TableColumn fx:id="col_alumno" text="Alumno" prefWidth="200"/>
            <TableColumn fx:id="col_fecha" text="Fecha de Pago" prefWidth="120"/>
            <TableColumn fx:id="col_monto" text="Monto" prefWidth="100"/>
            <TableColumn fx:id="col_metodo" text="Método" prefWidth="120"/>
            <TableColumn fx:id="col_accion" text="Acción" prefWidth="120"/>
        </columns>
    </TableView>

</VBox>