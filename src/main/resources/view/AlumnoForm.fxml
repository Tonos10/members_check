<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>

<GridPane xmlns="http://javafx.com/javafx/17"
          xmlns:fx="http://javafx.com/fxml/1"
          fx:controller="controller.AlumnoFormController"
          hgap="15" vgap="12"
          stylesheets="/css/dashboard.css"
          style="-fx-background-color: #FFFFFF; -fx-padding: 20;">

    <columnConstraints>
        <javafx.scene.layout.ColumnConstraints halignment="RIGHT" minWidth="120.0" prefWidth="120.0" />
        <javafx.scene.layout.ColumnConstraints hgrow="ALWAYS" minWidth="200.0" />
    </columnConstraints>

    <Label text="Información del Alumno" styleClass="page-title"
           GridPane.rowIndex="0" GridPane.columnIndex="0" GridPane.columnSpan="2"/>

    <Label text="Nombre:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
    <TextField fx:id="txtNombre" promptText="Ingresa el nombre"
               styleClass="text-field" prefWidth="200"
               GridPane.rowIndex="1" GridPane.columnIndex="1"/>

    <Label text="Fecha de Pago:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
    <DatePicker fx:id="dpFechaIngreso" styleClass="date-picker" prefWidth="200"
                GridPane.rowIndex="2" GridPane.columnIndex="1"/>

    <Label text="Teléfono:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
    <TextField fx:id="txtTelefono" promptText="Ej. 222..."
               styleClass="text-field" prefWidth="200"
               GridPane.rowIndex="3" GridPane.columnIndex="1"/>

    <Label text="F. Nacimiento:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
    <DatePicker fx:id="dpFechaNac" styleClass="date-picker" prefWidth="200"
                GridPane.rowIndex="4" GridPane.columnIndex="1"/>

    <Label text="Método de Pago:" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
    <javafx.scene.control.ComboBox fx:id="combo_box_pago" promptText="Seleccione método"
               styleClass="combo-box-cristal" prefWidth="200"
               GridPane.rowIndex="5" GridPane.columnIndex="1"/>

    <Label text="Cantidad Pagada:" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
    <TextField fx:id="txt_cantidad_pagada" promptText="Ej. 500"
               styleClass="text-field" prefWidth="200"
               GridPane.rowIndex="6" GridPane.columnIndex="1"/>

    <HBox spacing="10.0" alignment="CENTER_RIGHT"
          GridPane.rowIndex="7" GridPane.columnIndex="0" GridPane.columnSpan="2">
        <padding>
            <Insets top="10"/>
        </padding>
        <Button text="Guardar" onAction="#update_alumno_data" styleClass="btn-blue" prefWidth="100.0"/>
        <Button text="Cancelar" onAction="#cerrarVentana" styleClass="btn-light" prefWidth="100.0"/>
    </HBox>

</GridPane>
